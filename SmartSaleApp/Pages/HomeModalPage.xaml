<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartSaleApp.ViewModels"
             xmlns:c="clr-namespace:SmartSaleApp.Converters"
             x:Class="SmartSaleApp.Pages.HomeModalPage"
             x:DataType="vm:HomeModalViewModel"
             BackgroundColor="#80000000">

    <ContentPage.Resources>
        <c:StringToIntConverter x:Key="StringToIntConverter" />
        <c:StringToDoubleConverter x:Key="StringToDoubleConverter"  />
    </ContentPage.Resources>

    <Frame BackgroundColor="White" 
           VerticalOptions="Center" 
           HorizontalOptions="Center" 
           WidthRequest="350" 
           HeightRequest="400" 
           CornerRadius="10">

        <StackLayout>
            <Grid Padding="0,0,0,30" >
                <Label Text="{Binding Number, StringFormat='№ {0}'}"
                       FontSize="18"
                       VerticalOptions="End" />

                <Button Text="X"
                        Clicked="Close"
                        WidthRequest="40" 
                        HeightRequest="40"
                        HorizontalOptions="End" />
            </Grid>

            <Picker ItemsSource="{Binding ProductViewModels}" 
                    ItemDisplayBinding="{Binding .}" 
                    SelectedItem="{Binding ProductViewModel}"            
                    Title="Наименование"
                    FontSize="18" />

            <Entry Text="{Binding Count, Converter={StaticResource StringToIntConverter}}" 
                   Placeholder="Кол-во" 
                   Keyboard="Numeric"
                   FontSize="18"
                   MaxLength="3"/>

            <Entry Text="{Binding Price, Converter={StaticResource StringToDoubleConverter}}" 
                   Placeholder="Цена" 
                   Keyboard="Numeric"
                   FontSize="18"
                   MaxLength="4"/>

            <Label Text="{Binding Total, StringFormat='Итого: {0:N0}'}" 
                   Margin="0,20,0,0"
                   HorizontalOptions="Center"
                   FontSize="18" />

            <Button Text="Сохранить" 
                    Margin="0,50,0,0"
                    Command="{Binding SaveCommand}"
                    FontSize="18" />

        </StackLayout>
    </Frame>
</ContentPage>