<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"        
             xmlns:vm="clr-namespace:SmartSaleApp.ViewModels"
             xmlns:c="clr-namespace:SmartSaleApp.Converters"
             x:Class="SmartSaleApp.Pages.ProductModalPage"
             BackgroundColor="#80000000" >

    <ContentPage.Resources>
        <c:StringToIntConverter x:Key="StringToIntConverter" />
        <c:StringToDoubleConverter x:Key="StringToDoubleConverter"  />
    </ContentPage.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Frame Grid.Row="1" Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" Text="Карточка товара" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="X" Clicked="Close" />
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="3*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Entry Grid.Row="1" Text="{Binding Name}" Placeholder="Наименование" />

                    <Entry Grid.Row="2" Text="{Binding CountInPackage, Converter={StaticResource StringToIntConverter}}" 
                           Placeholder="Кол-во в упаковке"
                           Keyboard="Numeric"
                           MaxLength="5"/>

                    <Entry Grid.Row="3" Text="{Binding Count, Converter={StaticResource StringToIntConverter}}" 
                           Placeholder="Кол-во" 
                           Keyboard="Numeric"
                           MaxLength="3"/>

                    <Entry Grid.Row="4" Text="{Binding Price, Converter={StaticResource StringToDoubleConverter}}"
                           Placeholder="Цена" 
                           Keyboard="Numeric"
                           MaxLength="4"/>

                    <Button Grid.Row="6" Text="Сохранить"
                            Command="{Binding SaveCommand}"  />
                </Grid>
            </Grid>
        </Frame>
    </Grid>

</ContentPage>