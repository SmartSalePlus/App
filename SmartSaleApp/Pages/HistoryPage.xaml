<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartSaleApp.Pages.HistoryPage" >

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="10" Padding="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Text="С" VerticalOptions="Center"/>
            <DatePicker Grid.Column="1" Date="{Binding DateBegin}" Format="dd-MM-yyyy" />
            <Label Grid.Column="3" Text="По" VerticalOptions="Center"/>
            <DatePicker Grid.Column="4" Date="{Binding DateEnd}" Format="dd-MM-yyyy" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Picker Grid.Column="0" ItemsSource="{Binding Buyers}" ItemDisplayBinding="{Binding Name}" 
                    SelectedItem="{Binding Buyer}" />


            <Label Grid.Column="2" Text="Расчет" VerticalOptions="Center" >
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SetIsPaidCommand}" />
                </Label.GestureRecognizers>
            </Label>
            
            <CheckBox Grid.Column="3" IsChecked="{Binding IsPaid}" />
        </Grid>
        
        <ScrollView Grid.Row="2" Padding="4">
            <CollectionView ItemsSource="{Binding InvoiceViewModels}" 
                    SelectionMode="Single" >
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="20" />
                </CollectionView.ItemsLayout>
                <CollectionView.Header>
                    <Grid ColumnSpacing="4" Padding="4,10,4,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="0.6*"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Text="Дата" />
                        <Label Grid.Column="1" Text="Клиент" />
                        <Label Grid.Column="2" Text="Сумма" />
                        <Label Grid.Column="3" Text="Расчет" />
                    </Grid>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            
                            <Grid ColumnSpacing="4" Padding="4,10,4,10" >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="0.6*"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Column="0" Text="{Binding Date}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding Buyer.Name}" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding TotalWithDiscount, StringFormat='{0:N0}'}" VerticalOptions="Center" />
                                <CheckBox Grid.Column="3" IsChecked="{Binding IsPaid}" IsEnabled="False" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

        <Button Grid.Row="3" Text="Загрузить" Command="{Binding LoadCommand}" />
    </Grid>
</ContentPage>