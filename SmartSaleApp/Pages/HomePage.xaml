<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartSaleApp.ViewModels"
             xmlns:c="clr-namespace:SmartSaleApp.Converters"
             x:Class="SmartSaleApp.Pages.HomePage" >

    <ContentPage.Resources>
        <c:StringToDoubleConverter x:Key="StringToDoubleConverter"  />
    </ContentPage.Resources>

    <VerticalStackLayout>
        <VerticalStackLayout Padding="20,20,20,20">
            <DatePicker Date="{Binding Date}" 
                            Format="dd.MMMM.yyyy" />

            <Picker ItemsSource="{Binding Buyers}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding Buyer}"/>

            <ScrollView HeightRequest="300">
                <!--<ListView ItemsSource="{Binding InvoiceDetailViewModels}" 
                          SelectionMode="Single" 
                          SelectedItem="{Binding InvoiceDetailViewModel, Mode=TwoWay}">
                    <ListView.Header>
                        <HorizontalStackLayout Padding="8" Spacing="4" BackgroundColor="White">
                            <Label Text="№" WidthRequest="20" />
                            <Label Text="Наименование" WidthRequest="190" />
                            <Label Text="К-во" WidthRequest="30" />
                            <Label Text="Цена" WidthRequest="40" />
                            <Label Text="Сумма" WidthRequest="65" HorizontalTextAlignment="End" />
                        </HorizontalStackLayout>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ViewCell>
                                <HorizontalStackLayout Padding="8" Spacing="4" BackgroundColor="White">
                                    <Label Text="{Binding Number}" WidthRequest="20" />
                                    <Label Text="{Binding ProductViewModel}" WidthRequest="190" />
                                    <Label Text="{Binding Count}" WidthRequest="30" />
                                    <Label Text="{Binding Price}" WidthRequest="40" />
                                    <Label Text="{Binding Total}" WidthRequest="65" HorizontalTextAlignment="End" />
                                </HorizontalStackLayout>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>-->
                <CollectionView ItemsSource="{Binding InvoiceDetailViewModels}" 
                                SelectionMode="Single"         
                                SelectedItem="{Binding InvoiceDetailViewModel}" >
                    <CollectionView.Header>
                        <HorizontalStackLayout Padding="8" Spacing="4" BackgroundColor="White">
                            <Label Text="№" WidthRequest="20" />
                            <Label Text="Наименование" WidthRequest="190" />
                            <Label Text="К-во" WidthRequest="30" />
                            <Label Text="Цена" WidthRequest="40" />
                            <Label Text="Сумма" WidthRequest="65" HorizontalTextAlignment="End" />
                        </HorizontalStackLayout>
                    </CollectionView.Header>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <HorizontalStackLayout Padding="8" Spacing="4" BackgroundColor="White">
                                <Label Text="{Binding Number}" WidthRequest="20" />
                                <Label Text="{Binding ProductViewModel}" WidthRequest="190" />
                                <Label Text="{Binding Count}" WidthRequest="30" />
                                <Label Text="{Binding Price}" WidthRequest="40" />
                                <Label Text="{Binding Total}" WidthRequest="65" HorizontalTextAlignment="End" />
                            </HorizontalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>
            <StackLayout Orientation="Horizontal" Padding="8,8,8,0" VerticalOptions="Center">
                <Label Text="{Binding Total, StringFormat='Итого: {0}'}"
                       WidthRequest="250"
                       VerticalOptions="Center" />

                <Entry Text="{Binding Discount, Converter={StaticResource StringToDoubleConverter}}"
                       Placeholder="Скидка"
                       Keyboard="Numeric"
                       MaxLength="5"
                       WidthRequest="100" 
                       HorizontalOptions="End"
                       VerticalOptions="Center" />
            </StackLayout>
            <StackLayout Orientation="Horizontal" Padding="8,0,8,0" VerticalOptions="Center">
                <Label Text="{Binding TotalWithDiscount, StringFormat='Итого со скидкой: {0}'}"
                       WidthRequest="240"
                       VerticalOptions="Center" />

                <CheckBox IsChecked="{Binding IsPaid}" 
                              VerticalOptions="Center" />

                <Label Text="Расчет"
                           VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetIsPaidCommand}" />
                    </Label.GestureRecognizers>
                </Label>

            </StackLayout>
        </VerticalStackLayout>

        <HorizontalStackLayout Padding="8" Spacing="10" HorizontalOptions="End">
            <Button Text="Сохранить"
                    Command="{Binding SaveCommand}"/>
            <Button Text="Сброс"
                    Clicked="Reset" />

            <Button Text="Добавить товар"
                    Command="{Binding AddCommand}" />

        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>