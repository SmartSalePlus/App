<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SmartSaleApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SmartSaleApp.Pages"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Home">
            <ShellContent ContentTemplate="{DataTemplate local:HomePage}" Route="HomePage" />
        </Tab>

        <Tab Title="History">
            <ShellContent ContentTemplate="{DataTemplate local:HistoryPage}" Route="HistoryPage" />
        </Tab>

        <Tab Title="Buyer">
            <ShellContent ContentTemplate="{DataTemplate local:BuyerPage}" Route="BuyerPage" />
        </Tab>
    </TabBar>

</Shell>
