<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartSaleApp.Pages.ProductPage"
             Title="Товары">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="8*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CollectionView Grid.Row="0" ItemsSource="{Binding ProductViewModels}" SelectionMode="Single" SelectedItem="{Binding ProductViewModel}" >
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="20" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Text="{Binding .}" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{Binding Count}" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="{Binding Price}" VerticalOptions="Center" />
                            <!--<Button Grid.Column="1" Text="Удалить" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BuyerViewModel}}, Path=DeleteCommand}" CommandParameter="{Binding .}" />-->
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="1" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Text="Добавить" Command="{Binding AddCommand}" />
            <Button Grid.Column="2" Text="Загрузить" Command="{Binding LoadCommand}" />
        </Grid>
    </Grid>
    
</ContentPage>