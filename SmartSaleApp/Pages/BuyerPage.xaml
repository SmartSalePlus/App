<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartSaleApp.ViewModels"
             x:Class="SmartSaleApp.Pages.BuyerPage"
             Title="Клиенты">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="10*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Text="{Binding DateTimeLoad, StringFormat='Загружены в: {0}'}" />
        
        <CollectionView Grid.Row="1" ItemsSource="{Binding Buyers}" SelectionMode="Single" SelectedItem="{Binding Buyer}" >
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="20" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Label Grid.Column="0" Text="{Binding Name}" VerticalOptions="Center" />
                            <!--<Button Grid.Column="1" Text="Удалить" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BuyerViewModel}}, Path=DeleteCommand}" CommandParameter="{Binding .}" />-->
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Text="Загрузить" Command="{Binding LoadCommand}" />
            <Button Grid.Column="2" Text="Добавить" Command="{Binding AddCommand}" />
        </Grid>
    </Grid>
</ContentPage>